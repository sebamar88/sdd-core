{
  "schema": "sdd.adapter-capabilities.v1",
  "adapter": "cursor",
  "version": "0.1.0",
  "description": "Concrete adapter manifest for running SSD-Core with Cursor (Chat, Composer, Agent mode) while keeping repository artifacts as the source of truth.",
  "host": {
    "agent_runtime": "cursor",
    "operating_system": "any",
    "path_translation": true,
    "process_execution": "integrated-terminal",
    "state_location": "runtime-owned-outside-sdd-core",
    "recommended_invocation": "cursor-composer-or-agent-mode"
  },
  "profiles": {
    "supported": ["quick", "standard", "bugfix", "refactor", "enterprise", "research"],
    "selection": "smallest-safe-profile"
  },
  "agents": {
    "supported": ["orchestrator", "explorer", "specifier", "architect", "planner", "implementer", "verifier", "critic", "archivist"],
    "mapping": {
      "orchestrator": "cursor-composer-session",
      "explorer": "codebase-search-and-file-reading",
      "specifier": "artifact-authoring-pass",
      "architect": "design-review-pass",
      "planner": "task-breakdown-pass",
      "implementer": "code-editing-via-composer-or-inline",
      "verifier": "terminal-command-and-evidence-pass",
      "critic": "review-pass",
      "archivist": "sync-and-archive-pass"
    },
    "delegation": "single-agent-with-composer-edits"
  },
  "skills": {
    "supported": ["propose", "specify", "design", "task", "implement", "verify", "critique", "sync-specs", "archive"],
    "mapping": "load .sdd/skills/<skill>.md as phase instructions before acting"
  },
  "verification": {
    "command_execution": true,
    "manual_evidence": true,
    "screenshot_evidence": "not-available",
    "required_core_commands": ["ssd-core validate", "ssd-core status", "ssd-core check <change-id>"]
  },
  "state": {
    "source_of_truth": "repository-artifacts",
    "resume_active_change": true,
    "runtime_state_must_not_be_committed": true
  }
}
