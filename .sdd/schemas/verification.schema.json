{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdd-core.local/schemas/verification.schema.json",
  "title": "SDD-Core Verification Record",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "change_id", "status", "matrix"],
  "properties": {
    "schema": {
      "const": "sdd.verification.v1"
    },
    "change_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "in_progress", "blocked", "verified"]
    },
    "matrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["requirement", "evidence", "status"],
        "properties": {
          "requirement": {
            "type": "string",
            "minLength": 1
          },
          "scenario": {
            "type": "string"
          },
          "tasks": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "description", "status"],
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": ["test", "typecheck", "lint", "build", "static-analysis", "screenshot", "manual-check", "log", "review", "other"]
                },
                "description": {
                  "type": "string",
                  "minLength": 1
                },
                "status": {
                  "type": "string",
                  "enum": ["pass", "fail", "blocked", "not-run"]
                },
                "reference": {
                  "type": "string"
                }
              }
            }
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "blocked", "not-run"]
          }
        }
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
